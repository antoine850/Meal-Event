# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Resend (email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@mealevent.com

# SignNow (e-signature)
SIGNNOW_CLIENT_ID=your-signnow-client-id
SIGNNOW_CLIENT_SECRET=your-signnow-client-secret
SIGNNOW_API_BASE=https://api.signnow.com
SIGNNOW_WEBHOOK_SECRET=your-signnow-webhook-secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
