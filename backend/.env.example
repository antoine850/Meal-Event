# SignNow (e-signature)
# SignNow uses OAuth 2.0 with grant_type=password
# You need both API credentials (client_id/secret) AND user credentials (username/password)
SIGNNOW_CLIENT_ID=your-client-id
SIGNNOW_CLIENT_SECRET=your-client-secret
SIGNNOW_USERNAME=your-signnow-account-email@example.com
SIGNNOW_PASSWORD=your-signnow-account-password
# API Base URLs:
# - Sandbox: https://api-eval.signnow.com
# - Production: https://api.signnow.com
SIGNNOW_API_BASE=https://api-eval.signnow.com
SIGNNOW_WEBHOOK_SECRET=your-signnow-webhook-secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Google OAuth Calendar (client dedie Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail (phase 1) — client OAuth dedie, distinct de Calendar (app Internal
# propre aux scopes gmail restricted). Laisser GMAIL_INTEGRATION_ENABLED
# absent/false tant que la console Google Cloud n'est pas configuree.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_TOKEN_ENC_KEY=
GMAIL_OAUTH_STATE_SECRET=
GMAIL_INTEGRATION_ENABLED=false

# Gmail phase 2 : envoi via la boite du commercial. Effectif seulement si
# GMAIL_INTEGRATION_ENABLED=true. OFF => 100% Resend meme si des boites sont connectees.
GMAIL_SENDING_ENABLED=false
# Gmail phase 3 : polling des reponses dans les fils suivis. Effectif seulement
# si GMAIL_INTEGRATION_ENABLED=true. Intervalle en ms (defaut 180000 = 3 min).
GMAIL_POLLING_ENABLED=false
GMAIL_POLLING_INTERVAL_MS=180000

